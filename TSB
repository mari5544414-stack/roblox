local ESP_Settings = { Names = false, Distance = false }

-- [ЛОГИКА ESP]
local function createESP(p)
    local function onChar(char)
        local head = char:WaitForChild("Head", 10)
        if not head then return end
        if head:FindFirstChild("DoctorESP") then head.DoctorESP:Destroy() end
        local bgui = Instance.new("BillboardGui", head)
        bgui.Name = "DoctorESP"
        bgui.AlwaysOnTop, bgui.Size = true, UDim2.new(0, 200, 0, 50)
        bgui.StudsOffset = Vector3.new(0, 2.5, 0)
        local tl = Instance.new("TextLabel", bgui)
        tl.BackgroundTransparency, tl.Size = 1, UDim2.new(1, 0, 1, 0)
        tl.TextColor3, tl.TextSize = Color3.fromRGB(160, 32, 240), 14
        tl.TextStrokeTransparency = 0
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if not p.Parent or not char.Parent or not head.Parent then connection:Disconnect() if bgui then bgui:Destroy() end return end
            if (ESP_Settings.Names or ESP_Settings.Distance) and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    local dist = math.floor((player.Character.HumanoidRootPart.Position - root.Position).Magnitude)
                    local text = ESP_Settings.Names and p.DisplayName or ""
                    if ESP_Settings.Distance then text = text .. (text ~= "" and " | " or "") .. dist .. "m" end
                    tl.Text, tl.Visible = text, true
                else tl.Visible = false end
            else tl.Visible = false end
        end)
    end
    if p.Character then onChar(p.Character) end
    p.CharacterAdded:Connect(onChar)
end
for _, p in pairs(Players:GetPlayers()) do if p ~= player then createESP(p) end end
Players.PlayerAdded:Connect(createESP)

-- [ЛОГИКА ПОЛЕТА]
local bodyVelocity, bodyGyro
local function toggleFly(state)
    flying = state
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if flying and root and hum then
        bodyVelocity = Instance.new("BodyVelocity", root)
        bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bodyGyro = Instance.new("BodyGyro", root)
        bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
        hum.PlatformStand = true
    else
        if bodyVelocity then bodyVelocity:Destroy() end
        if bodyGyro then bodyGyro:Destroy() end
        if hum then hum.PlatformStand = false hum:ChangeState(11) end
    end
end

-- [ОБНОВЛЕННЫЙ СУПЕР ТРОЛЛЬ]
local function runAdvancedSuperTroll(targetPlayer)
    if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local myRoot = player.Character:FindFirstChild("HumanoidRootPart")
    local targetRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot or not targetRoot then return end

    local existingGui = playerGui:FindFirstChild("TrollAction")
    if existingGui then existingGui:Destroy() end

    local trollGui = Instance.new("ScreenGui", playerGui)
    trollGui.Name = "TrollAction"
    
    local actionBtn = Instance.new("TextButton")
    actionBtn.Size = UDim2.new(0, 180, 0, 60)
    actionBtn.Position = UDim2.new(0.5, -90, 0.2, 0)
    actionBtn.Text = "TP & ABYSS (R)"
    actionBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 50)
    actionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    actionBtn.Font = Enum.Font.SourceSansBold
    actionBtn.TextSize = 18
    actionBtn.Parent = trollGui

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 20, 0, 20)
    closeBtn.Position = UDim2.new(1, -20, 0, 0)
    closeBtn.Text = "X"
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
    closeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeBtn.Parent = actionBtn
    closeBtn.Activated:Connect(function() trollGui:Destroy() end)

    local function executeAction()
        if not actionBtn.Active then return end
        
        noclipEnabled = true
        actionBtn.Active = false
        actionBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        
        -- 1. ТП прямо к игроку
        actionBtn.Text = "SNATCHING..."
        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 1)
        task.wait(0.1)

        -- 2. Уходим на 100 блоков вниз
        actionBtn.Text = "GOING DEEP..."
        local targetPos = targetRoot.Position
        local deepY = targetPos.Y - 100 
        
        local attempts = 0
        repeat
            myRoot.CFrame = CFrame.new(targetPos.X, deepY, targetPos.Z)
            task.wait(0.05)
            attempts = attempts + 1
        until (myRoot.Position.Y <= deepY + 5) or attempts > 20

        -- 3. Удержание
        actionBtn.Text = "PULLING..."
        local bv = Instance.new("BodyVelocity")
        bv.Velocity = Vector3.new(0, -500, 0)
        bv.MaxForce = Vector3.new(0, 999999, 0)
        bv.Parent = myRoot
        
        task.wait(0.8)
        bv.Velocity = Vector3.new(0, 0, 0)
        myRoot.Anchored = true
        
        actionBtn.Text = "STAYING (5s)"
        task.wait(5)
        
        myRoot.Anchored = false
        bv:Destroy()
        noclipEnabled = false
        
        if actionBtn and actionBtn.Parent then
            actionBtn.Active = true
            actionBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 50)
            actionBtn.Text = "TP & ABYSS (R)"
        end
    end

    actionBtn.Activated:Connect(executeAction)
    
    local keyConnection
    keyConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not trollGui.Parent then keyConnection:Disconnect() return end
        if not gameProcessed and input.KeyCode == Enum.KeyCode.R then
            executeAction()
        end
    end)
end

-- [ЛОГИКА ТЕЛЕПОРТА К БЛИЖАЙШЕМУ НА E]
local function getClosestPlayer()
    local closest = nil
    local shortestDist = math.huge
    local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    
    if not myRoot then return nil end

    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (myRoot.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if dist < shortestDist then
                shortestDist = dist
                closest = p
            end
        end
    end
    return closest
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.E then
        local target = getClosestPlayer()
        local myRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if target and myRoot then
            myRoot.CFrame = target.Character.HumanoidRootPart.CFrame
        end
    end
end)

