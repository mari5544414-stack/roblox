-- [ОСНОВНОЙ ЦИКЛ]
RunService.Stepped:Connect(function()
    pcall(function()
        local char = player.Character
        if char and char:FindFirstChild("Humanoid") then
            local hum, root = char.Humanoid, char.HumanoidRootPart
            if flying and bodyVelocity and bodyGyro then
                bodyVelocity.Velocity = workspace.CurrentCamera.CFrame:VectorToWorldSpace(hum.MoveDirection * targetSpeed)
                bodyGyro.CFrame = workspace.CurrentCamera.CFrame
            else
                hum.WalkSpeed = hum.MoveDirection.Magnitude > 0 and targetSpeed or 0
                hum.JumpPower = targetJump
                hum:SetStateEnabled(1, not antiRagdoll) hum:SetStateEnabled(0, not antiRagdoll)
            end
            if isTrolling and selectedPlayer and selectedPlayer.Character then
                root.CFrame = selectedPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,3.5)
            end
        end
    end)
end)

